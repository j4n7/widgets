<div class="widgets-manager">
  <section>
    <div class="widgets-manager-toolbar">
      <button type="button" data-action="create-text">Create Text Widget</button>
      <button type="button" data-action="create-party-actors">Create Party Actors Widget</button>
      <button type="button" data-action="clear-all">Clear All</button>
    </div>
  </section>

  <section>
    <h2>Current Widgets</h2>

    {{#if hasWidgets}}
      <div class="widgets-manager-list">
        {{#each widgets}}
          <article class="widgets-manager-item {{#unless visible}}is-hidden{{/unless}}">
            <div>
              <div><strong>{{title}}</strong></div>
              <div class="widgets-manager-item-meta">
                Type: {{type}} · Position: {{position.left}}, {{position.top}} · Locked: {{locked}} · Visible: {{visible}}
              </div>
            </div>
            <div class="widgets-manager-item-actions">
              <button
                type="button"
                class="widgets-manager-icon-button"
                data-action="toggle-lock"
                data-widget-id="{{id}}"
                title="{{#if locked}}Unlock widget{{else}}Lock widget{{/if}}"
                aria-label="{{#if locked}}Unlock widget{{else}}Lock widget{{/if}}"
              >
                <i class="fas {{#if locked}}fa-lock{{else}}fa-lock-open{{/if}}"></i>
              </button>

              <button
                type="button"
                class="widgets-manager-icon-button"
                data-action="toggle-visibility"
                data-widget-id="{{id}}"
                title="{{#if visible}}Hide widget{{else}}Show widget{{/if}}"
                aria-label="{{#if visible}}Hide widget{{else}}Show widget{{/if}}"
              >
                <i class="fas {{#if visible}}fa-eye{{else}}fa-eye-slash{{/if}}"></i>
              </button>

              <button
                type="button"
                class="widgets-manager-icon-button is-danger"
                data-action="delete-widget"
                data-widget-id="{{id}}"
                title="Delete widget"
                aria-label="Delete widget"
              >
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </article>
        {{/each}}
      </div>
    {{else}}
      <p>No widgets created yet.</p>
    {{/if}}
  </section>
</div>
